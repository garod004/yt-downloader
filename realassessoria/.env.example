# Configuracao principal de banco
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=realassessoria

# Fallback opcional (apenas se quiser tentar outro banco automaticamente)
DB_LOCAL_HOST=localhost
DB_LOCAL_PORT=3306
DB_LOCAL_USER=root
DB_LOCAL_PASS=
DB_LOCAL_NAME=realassessoria

# Envio SMTP para backup por e-mail
SMTP_HOST=smtp.seuprovedor.com
SMTP_PORT=587
SMTP_USER=seu-usuario@dominio.com
SMTP_PASS=sua-senha-ou-token
SMTP_SECURE=tls
SMTP_AUTH=1
SMTP_FROM_EMAIL=seu-usuario@dominio.com
SMTP_FROM_NAME=Sistema de Backup

# Destino e retencao do backup
BACKUP_EMAIL_TO=destino@dominio.com
BACKUP_PASSWORD_EMAIL_TO=destino@dominio.com
BACKUP_KEEP_FILES=10
BACKUP_ZIP_PASSWORD=
